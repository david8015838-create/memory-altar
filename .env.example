# Supabase 設定 - 請複製此檔案為 .env 並填入你的 Supabase 資訊
# 在 https://supabase.com 建立免費帳號後，從 Project Settings > API 取得這些值

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 你們的專屬空間 ID（任意字串，當作共享密碼）
# 例如：VITE_SPACE_ID=chen-and-xiaoyu-2024
VITE_SPACE_ID=our-memory-altar
